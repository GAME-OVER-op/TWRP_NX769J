# patch05: disable automatic security HAL startup during boot
# on property:init.svc.vendor.qseecomd=running
#     start vendor.keymint-qti

service vendor.keymint-qti /vendor/bin/hw/android.hardware.security.keymint-service-qti
    disabled
    class early_hal
    user root
    group root drmrpc
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib64/hw:/system/lib64:/sbin:/odm/lib64
    seclabel u:r:recovery:s0
